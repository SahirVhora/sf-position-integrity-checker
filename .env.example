# SF Position Integrity Checker — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# Your SF tenant OData v2 base URL (include trailing slash)
# Example: https://api4.successfactors.com/odata/v2/
SF_ODATA_BASE_URL=https://<your-tenant>.successfactors.com/odata/v2/

# Basic Auth credentials for your SF API user
SF_USERNAME=your_sf_api_username
SF_PASSWORD=your_sf_api_password

# Optional: Company ID (required for some SF tenants)
SF_COMPANY_ID=your_company_id
