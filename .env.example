# SF Position Integrity Checker - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# ─────────────────────────────────────────────────────────────
# AUTHENTICATION - choose ONE method: Basic Auth OR OAuth2
# ─────────────────────────────────────────────────────────────

# Auth method to use: "basic" or "oauth2" (default: basic)
SF_AUTH_METHOD=basic

# ── Basic Auth (SF_AUTH_METHOD=basic) ────────────────────────
SF_USERNAME=your_sf_api_username
SF_PASSWORD=your_sf_api_password

# ── OAuth2 SAML Bearer (SF_AUTH_METHOD=oauth2) ───────────────
# Client ID from SF Admin → OAuth2 Client Applications
SF_CLIENT_ID=your_oauth2_client_id

# SF Company ID (your tenant identifier)
SF_COMPANY_ID=your_company_id

# SF technical user ID for the API token
SF_USER_ID=your_sf_api_user_id

# Full token endpoint URL
# Example: https://api4.successfactors.com/oauth/token
SF_TOKEN_URL=https://<your-tenant>.successfactors.com/oauth/token

# Path to your PEM private key file (keep this file outside your project directory)
# Example: /home/yourname/.sf_keys/sf_private_key.pem
SF_PRIVATE_KEY_PATH=/path/to/your/private_key.pem

# ─────────────────────────────────────────────────────────────
# SF OData v2 base URL (required for both auth methods)
# ─────────────────────────────────────────────────────────────
SF_ODATA_BASE_URL=https://<your-tenant>.successfactors.com/odata/v2/
